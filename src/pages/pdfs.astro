---
import fs from 'fs';
import path from 'path';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

// Get list of PDFs from public/pdfs folder
const pdfDir = path.join(process.cwd(), 'public', 'pdfs');
let pdfFiles: Array<{ name: string; path: string }> = [];

if (fs.existsSync(pdfDir)) {
	const files = fs.readdirSync(pdfDir);
	pdfFiles = files
		.filter((file) => file.endsWith('.pdf'))
		.map((file) => ({
			name: file.replace('.pdf', '').replace(/[-_]/g, ' '),
			path: `/pdfs/${file}`,
		}))
		.sort((a, b) => a.name.localeCompare(b.name));
}

const selectedPdf = pdfFiles.length > 0 ? pdfFiles[0].path : null;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Documents & Resources" description="View and download nursing education documents and resources" />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				padding: 3em 2rem;
				display: grid;
				grid-template-columns: 150px 1fr;
				gap: 2rem;
			}

			.sidebar {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			.pdf-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}

			.pdf-list li {
				margin: 0;
			}

			.pdf-list a {
				display: block;
				padding: 0.75rem;
				background: rgb(var(--gray-light));
				border-radius: 4px;
				text-decoration: none;
				color: rgb(var(--black));
				border-left: 4px solid transparent;
				transition: all 0.2s ease;
			}

			.pdf-list a:hover,
			.pdf-list a.active {
				background: var(--accent);
				color: white;
				border-left-color: var(--accent-dark);
			}

			.viewer-section {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			.pdf-viewer {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				overflow: hidden;
				background: white;
				box-shadow: var(--box-shadow);
				min-height: 90vh;
			}

			.pdf-viewer iframe {
				width: 100%;
				height: 90vh;
				border: none;
			}

			.no-pdfs {
				padding: 2rem;
				text-align: center;
				background: rgb(var(--gray-light));
				border-radius: 8px;
			}

			.download-btn {
				display: inline-block;
				padding: 0.75rem 1.5rem;
				background: var(--accent);
				color: white;
				text-decoration: none;
				border-radius: 4px;
				transition: background 0.2s ease;
				align-self: flex-start;
			}

			.download-btn:hover {
				background: var(--accent-dark);
			}

			@media (max-width: 768px) {
				main {
					grid-template-columns: 1fr;
				}

				.pdf-list {
					flex-direction: row;
					flex-wrap: wrap;
				}

				.pdf-list a {
					flex: 1;
					min-width: 150px;
				}

				.pdf-viewer iframe {
					height: 400px;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<aside class="sidebar">
				<h3>Documents</h3>
				{
					pdfFiles.length > 0 ? (
						<ul class="pdf-list">
							{pdfFiles.map((pdf) => (
								<li>
									<a
										href={`#pdf`}
										data-pdf={pdf.path}
										class:list={['pdf-link', { active: pdf.path === selectedPdf }]}
										onclick={`event.preventDefault(); document.querySelector('[data-viewer]').src='${pdf.path}'; Array.from(document.querySelectorAll('.pdf-link')).forEach(el => el.classList.remove('active')); event.target.closest('a').classList.add('active');`}
									>
										📄 {pdf.name}
									</a>
								</li>
							))}
						</ul>
					) : (
						<p style="color: rgb(var(--gray)); font-size: 0.9em;">No PDFs available yet</p>
					)
				}
			</aside>

			<section class="viewer-section">
				<h2>Resources</h2>
				{
					selectedPdf ? (
						<>
							<div class="pdf-viewer">
								<iframe
									data-viewer
									src={selectedPdf}
									title="PDF Viewer"
									allow="fullscreen"
								/>
							</div>
							<a href={selectedPdf} download class="download-btn">
								⬇️ Download PDF
							</a>
						</>
					) : (
						<div class="no-pdfs">
							<p>No documents to display. Upload a PDF to the <code>/public/pdfs</code> folder to get started.</p>
							<p style="font-size: 0.9em; color: rgb(var(--gray));">
								Supported formats: PDF
							</p>
						</div>
					)
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
